# ============================================================
# MLLM-CTBench 全局路径配置（唯一改动入口）
# 用法：先 `cp configs/paths.env.example configs/paths.env` 并按机器改，
#       各脚本用 `source configs/paths.env` 读取。
# ============================================================

# ---- 仓库根（自动定位；一般不用改）----
export CTBENCH_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." && pwd)"

# ---- Base 模型（自行准备，仓库不含权重）----
export LLAVA_BASE="/path/to/llava-v1.5-7b"
export QWEN_BASE="/path/to/Qwen2.5-VL-3B-Instruct"

# ---- 数据（从 HuggingFace 下载后指过来，见 data/README.md）----
# reasoning_train / reasoning_test：每任务 <task>.json，字段 problem/solution(含CoT)/image
export TRAIN_DIR="${CTBENCH_ROOT}/data/reasoning_train"
export TEST_DIR="${CTBENCH_ROOT}/data/reasoning_test"
# img.zip 解压后的图片根；json 里的 image 字段相对此目录
export IMAGE_ROOT="${CTBENCH_ROOT}/data/images"

# ---- 训练/推理产物输出根（会被 .gitignore）----
export OUTPUT_ROOT="${CTBENCH_ROOT}/output"

# ---- 任务顺序（order3；论文 Order-A 对应 numglue 起头的另一序，见 docs）----
export TASK_ORDER="art OCR fomc science numglue math medical"

# ---- CoT 质量评估器（过程级评测用；见 eval/cot_quality）----
# 评估器模型（自行准备）；用 vLLM/sglang 起 OpenAI 兼容服务后填端点
export EVALUATOR_MODEL="/path/to/CoT-Evaluator"      # 论文用 Qwen2.5-VL-7B 训练的评估器
export EVAL_BASE_URL="http://127.0.0.1:30000"        # 评估器服务地址（不带 /v1）
export EVAL_SERVED_NAME="cot-evaluator"              # 与 --served-model-name 一致

# ---- conda 环境名（按机器改）----
export ENV_LLAVA="clmm"
export ENV_QWEN="qwen_cl"
